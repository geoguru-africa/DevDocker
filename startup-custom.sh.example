# Example 9: Set up custom environment variables
# Uncomment to add environment variables
# echo 'export MY_CUSTOM_VAR="value"' >> /etc/profile.d/custom-env.sh

# Example 10: Download and install a specific tool version
# Example: Install a specific version of Maven
# MAVEN_VERSION=3.9.5
# curl -L https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz -o /tmp/maven.tar.gz
# tar -xzf /tmp/maven.tar.gz -C /root/.local/
