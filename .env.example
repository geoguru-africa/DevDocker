# GeoServer DevDocker Environment Configuration
# Copy this file to .env and customize as needed

# Logging Configuration
# Log level for container operations (default: INFO)
# Options: DEBUG (detailed), INFO (normal), WARNING (warnings only), ERROR (errors only)
LOG_LEVEL=INFO

# Port Configuration
# SSH port for IDE connectivity (default: 2222)
SSH_PORT=2222

# JDWP debug port (default: 5005)
DEBUG_PORT=5005

# GeoServer web interface port (default: 8080)
GEOSERVER_PORT=8080

# Documentation server port (default: 8000, future feature)
DOCS_PORT=8000

# Build Configuration
# Set to 'true' to build and use local GeoTools (default: false)
# When false, GeoServer will use GeoTools from Maven Central
CUSTOM_GEOTOOLS=false

# Set to 'true' to build and use local GeoWebCache (default: false)
# When false, GeoServer will use GeoWebCache from Maven Central
CUSTOM_GEOWEBCACHE=false

# GeoServer Configuration
# Data directory location inside container
GEOSERVER_DATA_DIR=/opt/geoserver/data_dir

# Java memory settings
JAVA_OPTS=-Xms512m -Xmx2g

# Maven Configuration
# Maven mirror URL for classroom mode or custom Maven proxy (optional)
# Leave empty to use Maven Central directly
# Example for classroom mode: http://presenter-host:8081/repository/maven-public/
# Note: Maven fallback chain: 1) internal volume, 2) host repo (if mounted in docker-compose.yml),
#       3) classroom mirror (if set below), 4) Maven Central
MAVEN_MIRROR_URL=

# Timezone Configuration
# Container timezone (default: Africa/Johannesburg for South Africa)
# Use standard timezone names: Africa/Johannesburg, UTC, America/New_York, Europe/London, etc.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Africa/Johannesburg

# Webhook Notifications
# Webhook URL for task completion notifications (optional)
# Leave empty to disable notifications
WEBHOOK_URL=
